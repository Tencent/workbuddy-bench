# WorkBuddy Bench — local environment template.
#
# This project does not hardcode env var names. Which variables you actually
# need is decided by the configs/models/<provider>/<slug>.yaml you create:
#
#   model:
#     backend_url_env: MY_PROVIDER_BASE_URL   # the env var name you put here
#     backend_key_env: MY_PROVIDER_API_KEY    # must exist in .env / your shell
#
# Given the above, .env then needs the two matching lines:
#
#   MY_PROVIDER_BASE_URL=https://example.com/v1
#   MY_PROVIDER_API_KEY=sk-...
#
# The groups below mirror the provider directories commonly found under
# configs/models/, all commented out; uncomment and fill in real values, or add
# new ones named after your own backend_url_env / backend_key_env.

# Example: OpenAI-compatible backend
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-...

# Example: Gateway / internal proxy
# MYGATEWAY_BASE_URL=https://gateway.example.com/v1
# MYGATEWAY_API_KEY=...

# Example: self-hosted OpenAI-compatible backend
# CUSTOM_BASE_URL=https://your-backend.example.com/v1
# CUSTOM_API_KEY=...

# Note: some backends mount chat completions under a sub-path, so the base URL
# must include that sub-path, e.g.:
# CUSTOM_BASE_URL=https://your-backend.example.com/openapi
